---
const tabs = [
  { id: 'intro', icon: '🏠', label: '简介', active: true },
  { id: 'posts', icon: '📝', label: '文章', active: false },
  { id: 'tags', icon: '🏷️', label: '标签', active: false },
  { id: 'archive', icon: '📦', label: '归档', active: false },
];
---

<div class="taskbar">
  <button
    class="taskbar-start"
    type="button"
    onclick="toggleStartMenu()"
    aria-label="首页"
  >
    <span class="start-icon" aria-hidden="true">⭐</span>
    首页
  </button>

  <div class="taskbar-tabs" id="taskbarTabs">
    {
      tabs.map((tab) => (
        <button
          class:list={['taskbar-tab', { active: tab.active }]}
          type="button"
          onclick={`focusWindow('${tab.id}')`}
        >
          {tab.icon} {tab.label}
        </button>
      ))
    }
  </div>

  <div class="taskbar-clock" id="taskbarClock" aria-live="polite">00:00</div>
</div>
