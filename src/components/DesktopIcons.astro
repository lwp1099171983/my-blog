---
const icons = [
  { id: 'intro', icon: '🏠', label: '简介', href: '/#intro' },
  { id: 'posts', icon: '📝', label: '文章', href: '/#posts' },
  { id: 'tags', icon: '🏷️', label: '标签', href: '/#tags' },
  { id: 'archive', icon: '📦', label: '归档', href: '/#archive' },
  { id: 'search', icon: '🔍', label: '搜索', href: '/#search' },
  { id: 'about', icon: '👤', label: '关于', href: '/#about' },
  { id: 'portfolio', icon: '📁', label: '作品', href: '/#portfolio' },
];
---

<nav class="desktop-icons" aria-label="桌面导航">
  {icons.map((item) => (
    <a
      class="desktop-icon"
      href={item.href}
      aria-label={`打开${item.label}窗口`}
    >
      <span class="icon-sprite" aria-hidden="true">{item.icon}</span>
      <span class="icon-label">{item.label}</span>
    </a>
  ))}

  <div class="hit-counter" aria-label="访客计数器">
    访客<br />
    <span class="digits" id="hitCount">001337</span>
  </div>
</nav>
