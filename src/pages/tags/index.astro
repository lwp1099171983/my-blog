---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Window from '../../components/Window.astro';
import { getUniqueTags } from '../../lib/utils';

const tags = await getUniqueTags();
---

<BaseLayout title="标签云 | starlin的像素角落">
  <Window id="tags-page" title="标签 - 筛选器.exe" icon="🏷️" x={80} y={40} width={600} height={440} active maximized>
    <h2>🏷️ 所有标签</h2>
    {
      tags.length > 0 ? (
        <div class="tags-cloud">
          {tags.map(({ tag, count }) => (
            <a href={`/tags/${tag}`} class="pixel-tag" style="font-size:calc(var(--fs-mono-s) + 2px);">{tag} ({count})</a>
          ))}
        </div>
      ) : (
        <p style="color:var(--win-text-muted);font-size:var(--fs-mono-s);">暂无标签</p>
      )
    }
  </Window>
</BaseLayout>
