---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Window from '../../components/Window.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts } from '../../lib/utils';

const posts = await getPublishedPosts();
---

<BaseLayout title="文章列表 | starlin的像素角落">
  <Window id="posts-list" title="文章 - /blog/" icon="📝" x={80} y={40} width={740} height={520} active maximized>
    <h2>📰 全部文章</h2>
    <p style="font-size:var(--fs-mono-s);color:var(--win-text-muted);margin-bottom:10px;">
      共 {posts.length} 篇
    </p>
    {
      posts.length > 0 ? (
        posts.map((p) => <PostCard post={p} showCategory />)
      ) : (
        <p style="color:var(--win-text-muted);font-size:var(--fs-mono-s);">还没有文章。</p>
      )
    }
  </Window>
</BaseLayout>
