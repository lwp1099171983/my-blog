---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import DesktopIcons from '../components/DesktopIcons.astro';
import Taskbar from '../components/Taskbar.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'starlin的像素角落',
  description = 'starlin 的个人技术博客，记录技术笔记、项目心得',
  ogImage = undefined,
  ogType = undefined,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} ogImage={ogImage} ogType={ogType} noindex={noindex} />
  </head>
  <body>
    <div class="desktop-bg" aria-hidden="true"></div>

    <DesktopIcons />

    <slot />

    <Taskbar />

    <script src="/scripts/window-manager.js" defer></script>
  </body>
</html>
