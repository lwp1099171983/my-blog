---
import '../styles/global.css';
import Taskbar from '../components/Taskbar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'starlin的像素角落',
  description = 'starlin 的个人技术博客，记录技术笔记、项目心得',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="desktop-bg" aria-hidden="true"></div>

    <slot />

    <Taskbar />

    <script src="/scripts/window-manager.js" defer></script>
  </body>
</html>
